# Backend API URLs
# Default to same-origin API proxy for OpenShift routes.
# Override these via injected VITE_* env vars during frontend image build.
VITE_API_URL=
VITE_AUTH_API_URL=

# Confluence integration
VITE_CONFLUENCE_SPACE=

# Incident input limits
VITE_FILE_CONTENT_MIN_LENGTH=20
VITE_FILE_CONTENT_MAX_LENGTH=5000

# Security behavior for non-HTTPS hosts
VITE_ALLOW_INSECURE_HOSTS=localhost,127.0.0.1
