{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": true,
    "noEmitOnError": false,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "typeRoots": ["../../types", "../../node_modules/@types"]
  },
  "include": [
    "**/*.ts",
    "../../types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
