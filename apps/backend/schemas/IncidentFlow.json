{
  "name": "IncidentFlow",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the incident flow"
    },
    "description": {
      "type": "string",
      "description": "Original incident description text"
    },
    "flow_type": {
      "type": "string",
      "enum": [
        "network_map",
        "timeline",
        "mitre_attack",
        "multi"
      ],
      "description": "Type of flow diagram. Use 'multi' for flows containing all three types"
    },
    "diagram_data": {
      "type": "string",
      "description": "Mermaid diagram code or JSON structure (for single-flow types)"
    },
    "flows": {
      "type": "object",
      "description": "Object containing all flow types when flow_type is 'multi'",
      "properties": {
        "network_map": {
          "type": "string",
          "description": "Network map flow data as JSON string"
        },
        "timeline": {
          "type": "string",
          "description": "Timeline flow data as JSON string"
        },
        "mitre_attack": {
          "type": "string",
          "description": "MITRE ATT&CK flow data as JSON string"
        }
      }
    },
    "nodes": {
      "type": "array",
      "description": "Array of nodes in the diagram",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "generated",
        "reviewed",
        "archived"
      ],
      "default": "draft"
    }
  },
  "required": [
    "name",
    "flow_type"
  ]
}