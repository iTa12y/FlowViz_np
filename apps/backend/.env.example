# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Confluence Configuration
CONFLUENCE_URL=https://your-domain.atlassian.net

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT=30000

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Server Configuration
PORT=3001

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50

# Request Body Size Limit
REQUEST_BODY_SIZE_LIMIT=50kb

# Session/Cookie Configuration
SESSION_TTL_SECONDS=3600
SESSION_COOKIE_NAME=session_id
# SameSite: auto-defaults to 'none' when SESSION_COOKIE_SECURE=true (HTTPS/production),
# and 'lax' when SESSION_COOKIE_SECURE=false (HTTP/development).
# For OpenShift with separate frontend/backend routes, set both to none + true.
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false

# Redis UX Hint
REDIS_START_COMMAND_HINT=redis-server

# Environment
NODE_ENV=development
